{
  "name": "incident-triage-studio",
  "version": 2,
  "buildCommand": "",
  "outputDirectory": null,
  "functions": {
    "api/mcp.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/health.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
